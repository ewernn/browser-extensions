{
  "manifest_version": 3,
  "name": "site-blocker-permissionless",
  "version": "1.0",
  "description": "Block sites by domain. No host permissions, no page access.",
  "browser_specific_settings": {
    "gecko": {
      "id": "site-blocker-permissionless@ewern.dev",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["declarativeNetRequest", "storage"],
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg",
    "128": "icon.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "site-blocker-permissionless",
    "default_icon": {
      "48": "icon.svg",
      "96": "icon.svg"
    }
  }
}
